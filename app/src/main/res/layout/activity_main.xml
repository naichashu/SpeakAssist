<?xml version="1.0" encoding="utf-8"?>
<!--
    首页主布局
    采用DrawerLayout实现侧滑菜单功能
    布局结构：
    1. 顶部导航栏（Toolbar）
    2. 权限提示横幅（权限缺失时显示）
    3. 聊天消息列表（RecyclerView）
    4. 底部输入栏
    5. 左侧侧栏（NavigationView）
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 主内容区域 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 顶部导航栏 -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:title="@string/app_name"
            app:titleTextColor="@android:color/white">

            <!-- 汉堡菜单图标 - 居中左侧 -->
            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="@string/menu_description" />

        </androidx.appcompat.widget.Toolbar>

        <!-- 权限提示横幅 -->
        <!-- 当权限未开启时显示，点击可跳转到设置页面 -->
        <LinearLayout
            android:id="@+id/permissionBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="#FFF3E0"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            tools:visibility="visible">

            <!-- 警告图标 -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:contentDescription="@string/permission_warning" />

            <!-- 提示文字 -->
            <TextView
                android:id="@+id/tvPermissionHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/permission_required_hint"
                android:textColor="#E65100"
                android:textSize="12sp" />

            <!-- 设置按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPermissionSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textSize="12sp"
                android:minHeight="32dp"
                style="@style/Widget.Material3.Button.TextButton" />

        </LinearLayout>

        <!-- 聊天消息列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChatMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/permissionBanner"
            app:layout_constraintBottom_toTopOf="@id/inputContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_chat_message" />

        <!-- 空状态提示 -->
        <!-- 当没有消息时显示 -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/permissionBanner"
            app:layout_constraintBottom_toTopOf="@id/inputContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_menu_help"
                android:alpha="0.5"
                android:contentDescription="@string/empty_state" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/empty_state_hint"
                android:textColor="#999999"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- 中央录音气泡 -->
        <!-- 长按"按住说话"时浮现，含音波动画 + 状态文案；gone 时不参与布局也不拦截事件 -->
        <FrameLayout
            android:id="@+id/voiceBubble"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:background="@drawable/bg_voice_bubble"
            android:elevation="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/permissionBanner"
            app:layout_constraintBottom_toTopOf="@id/inputContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <!-- 状态图标：默认麦克风 / 取消态 X -->
                <ImageView
                    android:id="@+id/ivBubbleIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:tint="@android:color/white"
                    android:contentDescription="@string/voice_input_description" />

                <!-- 音波动画 -->
                <com.example.ui.widget.WaveformView
                    android:id="@+id/waveformView"
                    android:layout_width="120dp"
                    android:layout_height="28dp"
                    android:layout_marginTop="14dp" />

                <!-- 状态提示文案 -->
                <TextView
                    android:id="@+id/tvBubbleHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/voice_swipe_up_hint"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- 底部输入栏容器 -->
        <LinearLayout
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="@android:color/white"
            android:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 输入模式切换按钮（最左）：键盘模式显示麦克风，语音模式显示键盘 -->
            <ImageButton
                android:id="@+id/btnInputMode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:contentDescription="@string/voice_input_mode_toggle"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp" />

            <!-- 输入区：键盘模式 (tilInput) 与语音模式 (btnPressToTalk) 互斥；
                 噪声指示叠在右上 -->
            <FrameLayout
                android:id="@+id/inputArea"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:hint="@string/input_hint"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLines="3"
                        android:inputType="textMultiLine"
                        android:imeOptions="actionSend" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 按住说话按钮：语音模式可见，键盘模式 gone -->
                <Button
                    android:id="@+id/btnPressToTalk"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical"
                    android:text="@string/voice_hold_to_speak"
                    android:textColor="@android:color/black"
                    android:background="@drawable/bg_press_to_talk"
                    android:visibility="gone"
                    tools:visibility="gone" />

                <View
                    android:id="@+id/noiseIndicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/shape_noise_dot"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 发送按钮：键盘模式可见，语音模式 gone -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_menu_send"
                android:contentDescription="@string/send_message"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 左侧侧栏（NavigationView） -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
