<?xml version="1.0" encoding="utf-8"?><!--
   Android 12+ 备份与设备迁移排除规则：与 backup_rules.xml 对齐。
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/" />
        <exclude domain="database" path="speakassist.db" />
        <exclude domain="database" path="speakassist.db-shm" />
        <exclude domain="database" path="speakassist.db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/" />
        <exclude domain="database" path="speakassist.db" />
        <exclude domain="database" path="speakassist.db-shm" />
        <exclude domain="database" path="speakassist.db-wal" />
    </device-transfer>
</data-extraction-rules>
