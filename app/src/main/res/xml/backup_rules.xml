<?xml version="1.0" encoding="utf-8"?><!--
   备份排除规则：API 凭据与任务历史不参与系统备份/迁移，
   防止 API Key 与历史命令明文随设备备份上云。
-->
<full-backup-content>
    <!-- 排除 API 凭据（DataStore Preferences） -->
    <exclude domain="file" path="datastore/" />
    <!-- 排除任务历史 DB（含截图触发的命令明文） -->
    <exclude domain="database" path="speakassist.db" />
    <exclude domain="database" path="speakassist.db-shm" />
    <exclude domain="database" path="speakassist.db-wal" />
</full-backup-content>
